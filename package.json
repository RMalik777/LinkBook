		"simple-icons": "^16.23.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.4.8",
		"svelte-eslint-parser": "^1.7.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "4.3.0",
		"tslib": "^2.8.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
